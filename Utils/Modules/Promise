--!native
--!optimize 2

type State = number

export type Promise<T> = {
	andThen: <U>(self: Promise<T>, fn:(T)->(U|Promise<U>)) -> Promise<U>,
	catch: (self: Promise<T>, fn:(any)->any) -> Promise<any>,
	finally: (self: Promise<T>, fn:()->()) -> Promise<T>,
	cancel: (self: Promise<T>) -> (),
	await: (self: Promise<T>) -> T,

	_state: State,
	_value: any,
	_callbacks: {any}?,
	_tag: {}
}

export type PromiseModule = {
	new: <T>(executor:(resolve:(T)->(), reject:(any)->())->()) -> Promise<T>,
	resolve: <T>(value:T) -> Promise<T>,
	reject: (err:any) -> Promise<any>,
	delay: (seconds:number) -> Promise<number>,
	all: <T>(promises:{Promise<T>}) -> Promise<{T}>,
	race: <T>(promises:{Promise<T>}) -> Promise<T>,
	any: <T>(promises:{Promise<T>}) -> Promise<T>,
	try: <T>(fn:()->(T|Promise<T>)) -> Promise<T>
}

local Promise = {} :: PromiseModule
Promise.__index = Promise

local PROMISE_TAG = {}

local PENDING:State = 0
local RESOLVED:State = 1
local REJECTED:State = 2
local CANCELLED:State = 3

local queueFn = table.create(256)
local queueChild = table.create(256)
local queueArg = table.create(256)

local qlen = 0
local flushing = false

local function flush()
	for i=1,qlen do
		queueFn[i](queueChild[i], queueArg[i])
		queueFn[i] = nil
		queueChild[i] = nil
		queueArg[i] = nil
	end

	qlen = 0
	flushing = false
end

local function schedule(fn, child, arg)
	local n = qlen + 1
	qlen = n

	queueFn[n] = fn
	queueChild[n] = child
	queueArg[n] = arg

	if not flushing then
		flushing = true
		task.defer(flush)
	end
end

local resolvePromise
local rejectPromise

local function isPromise(v:any):boolean
	return type(v) == "table" and v._tag == PROMISE_TAG
end

resolvePromise = function(promise,value)
	if promise._state ~= PENDING then
		return
	end
	if isPromise(value) then
		value
			:andThen(function(v)
				resolvePromise(promise,v)
			end)
			:catch(function(e)
				rejectPromise(promise,e)
			end)
		return
	end
	promise._state = RESOLVED
	promise._value = value
	local callbacks = promise._callbacks
	if not callbacks then return end

	promise._callbacks = nil
	for i=1,#callbacks,3 do
		schedule(callbacks[i], {callbacks[i+2], value})
	end
end

rejectPromise = function(promise,err)
	if promise._state ~= PENDING then
		return
	end
	promise._state = REJECTED
	promise._value = err
	local callbacks = promise._callbacks
	if not callbacks then return end
	promise._callbacks = nil
	for i=1,#callbacks,3 do
		schedule(callbacks[i+1], {callbacks[i+2], err})
	end
end

local function successHandler(child, fn, value)
	local ok, result = pcall(fn, value)

	if ok then
		resolvePromise(child, result)
	else
		rejectPromise(child, result)
	end
end

local function failHandler(child, err)
	rejectPromise(child, err)
end

function Promise.new(executor)
	local self = setmetatable({
		_state = PENDING,
		_value = nil,
		_callbacks = table.create(4),
		_tag = PROMISE_TAG
	},Promise)
	local function resolve(v)
		resolvePromise(self,v)
	end
	local function reject(e)
		rejectPromise(self,e)
	end
	local ok,err = pcall(executor,resolve,reject)
	if not ok then
		reject(err)
	end
	return self
end

function Promise:andThen(fn)
	local parent = self
	local child = setmetatable({
		_state = PENDING,
		_value = nil,
		_callbacks = nil,
		_tag = PROMISE_TAG
	},Promise)
	if parent._state == PENDING then
		local list = parent._callbacks
		if not list then
			list = table.create(3)
			parent._callbacks = list
		end
		local n = #list + 1
		list[n] = function(...)
			successHandler(...)
		end
		list[n+1] = failHandler
		list[n+2] = child
	elseif parent._state == RESOLVED then
		schedule(successHandler,{child,fn,parent._value})
	elseif parent._state == REJECTED then
		rejectPromise(child,parent._value)
	end
	return child
end

function Promise:catch(fn)
	return self:andThen(function(v)
		return v
	end,function(err)
		return fn(err)
	end)
end

function Promise:finally(fn)
	return self
		:andThen(function(v)
			fn()
			return v
		end)
		:catch(function(err)
			fn()
			error(err)
		end)
end

function Promise:cancel()
	if self._state ~= PENDING then return end
	self._state = CANCELLED
	self._callbacks = nil
end

function Promise:await()
	if self._state == RESOLVED then
		return self._value
	end
	if self._state == REJECTED then
		error(self._value)
	end
	local thread = coroutine.running()
	self:andThen(function(v)
		task.spawn(thread,v)
	end)
		:catch(function(e)
			task.spawn(thread,nil,e)
		end)
	local value,err = coroutine.yield()
	if err then error(err) end
	return value
end

function Promise.resolve(value)
	return setmetatable({
		_state = RESOLVED,
		_value = value,
		_callbacks = nil,
		_tag = PROMISE_TAG
	},Promise)
end

function Promise.reject(err)
	return setmetatable({
		_state = REJECTED,
		_value = err,
		_callbacks = nil,
		_tag = PROMISE_TAG
	},Promise)
end

function Promise.delay(seconds)
	return Promise.new(function(resolve)
		task.delay(seconds,function()
			resolve(seconds)
		end)
	end)
end

function Promise.all(promises)
	return Promise.new(function(resolve,reject)
		local count = #promises
		local remaining = count
		local results = table.create(count)
		if count == 0 then
			resolve(results)
			return
		end
		for i=1,count do
			promises[i]:andThen(function(v)
				results[i] = v
				remaining -= 1

				if remaining == 0 then
					resolve(results)
				end
			end):catch(reject)
		end
	end)
end

function Promise.race(promises)
	return Promise.new(function(resolve,reject)
		for i=1,#promises do
			promises[i]
				:andThen(resolve)
				:catch(reject)
		end
	end)
end

function Promise.any(promises)
	return Promise.new(function(resolve,reject)
		local fails = 0
		local total = #promises
		for i=1,total do
			promises[i]
				:andThen(resolve)
				:catch(function()

					fails += 1

					if fails == total then
						reject("All promises rejected")
					end

				end)
		end
	end)
end

function Promise.try(fn)
	return Promise.new(function(resolve,reject)
		local ok,result = pcall(fn)

		if not ok then
			reject(result)
			return
		end
		if isPromise(result) then
			result:andThen(resolve):catch(reject)
		else
			resolve(result)
		end
	end)
end

return Promise